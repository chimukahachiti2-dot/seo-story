{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific settings and metadata.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Story": {
      "title": "Generated Story",
      "description": "A story generated by the engine.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "viralHook": { "type": "string" },
        "fullStory": { "type": "string" },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "hashtags": { "type": "array", "items": { "type": "string" } },
        "scenes": { "type": "array", "items": { "$ref": "#/entities/Scene" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "videoReferences": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "title", "fullStory", "createdAt"]
    },
    "Scene": {
      "title": "Story Scene",
      "description": "A specific scene within a story.",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "visualHook": { "type": "string" },
        "imagePrompt": { "type": "string" },
        "videoPrompt": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "Collection of generated stories."
    }
  }
}
